// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  TO_CONTACT
  QUOTED
  REFUSED
  CONVERTED
}

enum RefusalReason {
  NO_ASSET
  PRICE_TOO_HIGH
  ALREADY_INSURED
  OTHER
}

enum ProductType {
  DRIVE
  HOME
  PENSION_PLAN
  OTHER
}

enum LeadSource {
  MANUAL
  API_EXTERNAL
}

enum ActionType {
  REFUSED
  REFUSAL_CANCELLED
  QUOTE_CREATED
  CALLBACK_SCHEDULED
  NOTE_ADDED
}

enum AgentRole {
  RESPONSABLE
  EMPLOYE
}

model Agent {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  password     String
  agencyNumber String    @map("agency_number")
  role         AgentRole @default(EMPLOYE)
  leads        Lead[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([agencyNumber])
  @@map("agents")
}

model Lead {
  id              String       @id @default(uuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  productInterest String       @map("product_interest")
  status          LeadStatus   @default(NEW)
  source          LeadSource   @default(MANUAL)
  externalId      String?      @unique
  agencyNumber    String       @map("agency_number")
  agentId         String
  agent           Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  actions         LeadAction[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([agentId])
  @@index([agencyNumber])
  @@index([status])
  @@map("leads")
}

model LeadAction {
  id            String         @id @default(uuid())
  leadId        String
  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type          ActionType
  refusalReason RefusalReason?
  refusalNote   String?
  quotedProduct ProductType?
  quoteUrl      String?
  quoteAmount   Float?
  callbackDate  DateTime?
  note          String?
  createdAt     DateTime       @default(now())
  createdBy     String

  @@index([leadId])
  @@map("lead_actions")
}
